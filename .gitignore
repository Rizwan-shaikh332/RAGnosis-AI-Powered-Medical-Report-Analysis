# ═══════════════════════════════════════════════
#  RAGnosis .gitignore
#  Covers: Python, Flask, React/Vite, Node.js,
#          MongoDB, ML models, OS & IDE files
# ═══════════════════════════════════════════════


# ─── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# Virtual environments
venv/
.venv/
env/
ENV/
.env/
Lib/
Include/
Scripts/
pyvenv.cfg

# Python packaging
*.egg
*.egg-info/
dist/
build/
*.whl
site-packages/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
*.log

# mypy / type checking
.mypy_cache/
.dmypy.json


# ─── Environment & Secrets ───────────────────
.env
.env.local
.env.development
.env.production
.env.test
*.env

# Keep the template (safe to commit)
!.env.template
!.env.example


# ─── Flask / Backend ─────────────────────────
backend/uploads/
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/instance/
backend/*.db
backend/*.sqlite3


# ─── ML Models & FAISS Index ─────────────────
# FAISS index files (large binary files, built locally)
models/faiss_index/
*.faiss
*.index
*.bin

# HuggingFace model cache (auto-downloaded)
# (These can be 1–4 GB each, never commit)
*.safetensors
*.h5
*.pkl
*.joblib

# Jupyter checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/


# ─── Node.js / React / Vite ──────────────────
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/build/
dist/

# Vite cache
frontend/.vite/
.vite/

# npm/yarn lock files (keep package-lock.json if used)
# yarn.lock
# pnpm-lock.yaml

# Storybook
storybook-static/


# ─── Android / Expo ──────────────────────────
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
android/*.keystore
android/*.jks
*.apk
*.aab

# Expo
.expo/
.expo-shared/


# ─── MongoDB / Database ──────────────────────
*.bson
mongodump/
mongoexport/


# ─── Uploaded Reports (user data, never commit) ──
uploads/
backend/uploads/
sample_reports/
*.pdf
*.PDF


# ─── OS Files ────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory


# ─── IDE & Editor ────────────────────────────
# VSCode
.vscode/*
!.vscode/extensions.json

# JetBrains (PyCharm, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
*.orig

# Sublime Text
*.sublime-project
*.sublime-workspace


# ─── Misc ────────────────────────────────────
*.tmp
*.temp
*.cache
*.bak
*.backup
*.log
logs/

backend/.env
backend/venv/
frontend/node_modules/
node_modules/
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
android/*.keystore
android/*.jks
*.apk
*.aab
.expo/
.expo-shared/