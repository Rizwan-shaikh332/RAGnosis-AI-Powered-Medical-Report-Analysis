# RAGnosis Environment Variables - Copy this to .env and fill in your values
MONGODB_URI=mongodb://localhost:27017/ragnosis
DB_NAME=ragnosis

# Get your free Groq API key from: https://console.groq.com
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
FRONTEND_URL=http://localhost:5173

# =============== OPTIONAL: Tesseract OCR Configuration ===============
# By default, Tesseract is auto-detected in common installation paths (Windows only)
# If Tesseract is installed in a non-standard location, set the full path here:
#
# Windows Example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
#
# macOS Example (if installed via Homebrew):
# TESSERACT_CMD=/usr/local/bin/tesseract
#
# Linux Example (if installed via apt):
# TESSERACT_CMD=/usr/bin/tesseract
#
# If not set, RAGnosis will auto-detect. Only set this if you have a non-standard installation.
# TESSERACT_CMD=YOUR_TESSERACT_PATH_HERE

